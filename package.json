{
  "name": "gestalt-mobile",
  "version": "0.1.0",
  "description": "Mobile-first web relay for durable Codex development sessions",
  "keywords": [
    "codex",
    "gestalt",
    "mobile",
    "development"
  ],
  "homepage": "https://github.com/dyne/gestalt-mobile#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dyne/gestalt-mobile.git"
  },
  "bugs": {
    "url": "https://github.com/dyne/gestalt-mobile/issues"
  },
  "author": "Dyne.org foundation",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "bin": {
    "gestalt-mobile": "dist/server/server/main.js"
  },
  "files": [
    "dist/server",
    "dist/client",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "tsx watch src/server/main.ts -- --cwd ..",
    "start": "node dist/server/server/main.js",
    "dev:client": "vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "node scripts/build-server.mjs",
    "build:client": "vite build",
    "prepack": "npm run build && npm run protocol:check",
    "check": "tsc -p tsconfig.server.json --noEmit && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:package": "node scripts/smoke-packed-cli.mjs",
    "test:e2e": "playwright test",
    "protocol:generate": "node scripts/generate-codex-protocol.mjs",
    "protocol:check": "node scripts/check-codex-protocol.mjs",
    "license:check": "node scripts/check-license-headers.mjs",
    "license:apply": "node scripts/apply-license-headers.mjs"
  },
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "fastify": "^5.10.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@testing-library/svelte": "^5.4.2",
    "@types/node": "^24.13.3",
    "@types/ws": "^8.18.1",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
